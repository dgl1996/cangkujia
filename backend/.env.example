# 仓酷家后端环境变量配置模板
# 复制此文件为 .env 并填入真实值
# ⚠️ 重要：不要将包含真实密钥的.env文件提交到GitHub

# ============================================
# Clerk 身份验证配置
# ============================================
# Clerk Secret Key (从Clerk Dashboard获取)
CLERK_SECRET_KEY=YOUR_CLERK_SECRET_KEY_HERE

# Clerk Publishable Key (前端使用)
CLERK_PUBLISHABLE_KEY=YOUR_CLERK_PUBLISHABLE_KEY_HERE
# ============================================
# 微信支付配置
# ============================================
# 微信支付商户号
WECHAT_MCH_ID=your_mch_id_here

# 微信支付AppID
WECHAT_APPID=your_appid_here

# 微信支付APIv3密钥
# ⚠️ 重要：必须使用回调专用密钥（商户平台→API安全→解调回调），不是签名密钥
WECHAT_APIV3_KEY=your_api_v3_key_here

# 微信支付回调通知URL
WECHAT_NOTIFY_URL=https://cangkujia666.com/api/payment/callback

# 微信支付API证书路径
WECHAT_CERT_PATH=/var/www/cangkujia/backend/certs/apiclient_cert.pem
WECHAT_KEY_PATH=/var/www/cangkujia/backend/certs/apiclient_key.pem

# 微信支付证书序列号
WECHAT_CERT_SERIAL_NO=your_cert_serial_no_here

# ============================================
# 数据库配置
# ============================================
# SQLite数据库URL（生产环境使用绝对路径）
DATABASE_URL=sqlite:////var/www/cangkujia/backend/cangkujia.db

# Supabase配置（可选，用于PostgreSQL）
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_key_here

# ============================================
# JWT 配置
# ============================================
# JWT 密钥（用于签名Token，生产环境请使用强随机字符串）
JWT_SECRET_KEY=your_jwt_secret_key_here_min_32_characters_long

# JWT Token 有效期（天）
JWT_EXPIRE_DAYS=30

# ============================================
# 服务器配置
# ============================================
# 服务器端口
PORT=8000

# CORS允许的源（多个用逗号分隔）
ALLOWED_ORIGINS=https://cangkujia666.com,http://localhost:5173

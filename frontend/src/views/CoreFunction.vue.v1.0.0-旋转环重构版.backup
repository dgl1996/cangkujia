<template>
  <div class="core-function">
    <div class="header">
      <h1>仓酷家 - 仓库布局设计</h1>
      <p>仓库户型图 + 3D物流对象资产 = 快速输出3D物流仓库效果图</p>
    </div>
    
    <div class="main-content">
      <div class="scene-container">
        <ThreeScene ref="threeScene" :floor-plan-src="floorPlanSrc" @model-added="onModelAdded" @layout-saved="onLayoutSaved" @layout-loaded="onLayoutLoaded" @object-selected="onObjectSelected" @object-deselected="onObjectDeselected" @batch-place-completed="onBatchPlaceCompleted" />
      </div>
      
      <div class="sidebar">
        <div class="panel">
          <h2>可用模型</h2>
          <div class="model-list">
            <div class="model-item" draggable="true" @dragstart="onDragStart($event, 'shelf_with_pallet.glb')">
              横梁式重型货架
            </div>
          </div>
          
          <h3>批量放置</h3>
          <div class="batch-controls">
            <div class="batch-steps">
              <p class="step-info">1. 选择模型：横梁式重型货架</p>
              <p class="step-info">2. 设置参数：</p>
            </div>
            <div class="control-group">
              <label>数量: {{ batchCount }} 个</label>
              <input type="range" v-model.number="batchCount" min="1" max="10" @input="updateBatchCount">
            </div>
            <div class="control-group">
              <label>间距: {{ batchSpacing }} 米</label>
              <input type="range" v-model.number="batchSpacing" min="1" max="5" @input="updateBatchSpacing">
            </div>
            <div class="control-group">
              <label>排列方向:</label>
              <div class="direction-buttons">
                <button 
                  :class="{ active: batchDirection === 'horizontal' }" 
                  @click="setBatchDirection('horizontal')">
                  水平排列
                </button>
                <button 
                  :class="{ active: batchDirection === 'vertical' }" 
                  @click="setBatchDirection('vertical')">
                  垂直排列
                </button>
              </div>
            </div>
            <p class="step-info">3. 点击按钮开始放置：</p>
            <button @click="startBatchPlace" :disabled="isBatchPlacing" class="batch-btn">
              {{ isBatchPlacing ? '点击场景放置...' : '开始批量放置' }}
            </button>
            <p v-if="isBatchPlacing" class="place-hint">请在场景中点击想要放置的起始位置</p>
          </div>
        </div>
        
        <div class="panel">
          <h2>操作</h2>
          <div class="control-buttons">
            <button @click="importFloorPlan">导入户型图</button>
            <button @click="saveLayout">保存布局</button>
            <button @click="loadLayout">加载布局</button>
            <button @click="exportImage">导出效果图</button>
            <button @click="clearScene">清空场景</button>
          </div>
        </div>
        
        <div class="panel" v-if="selectedObject">
          <h2>对象操作</h2>
          <div class="object-controls">
            <button @click="moveObject">移动</button>
            <button @click="startRotate" :class="{ active: isRotating }">
              {{ isRotating ? '拖动旋转' : '开始旋转' }}
            </button>
            <button @click="deleteObject">删除</button>
          </div>
          <p v-if="isRotating" class="rotate-hint">请在场景中拖动来旋转模型</p>
        </div>
      </div>
    </div>
    
    <input type="file" ref="fileInput" accept="image/*" style="display: none" @change="onFileChange">
    <input type="file" ref="layoutInput" accept=".json" style="display: none" @change="onLayoutFileChange">
  </div>
</template>

<script setup>
import { ref } from 'vue';
import ThreeScene from '../components/3d/ThreeScene.vue';

const threeScene = ref(null);
const fileInput = ref(null);
const layoutInput = ref(null);
const floorPlanSrc = ref('');
const rotationAngle = ref(0);
const selectedObject = ref(null);
const batchCount = ref(3);
const batchSpacing = ref(2);
const batchDirection = ref('horizontal');
const isBatchPlacing = ref(false);
const isRotating = ref(false);

function onDragStart(event, modelName) {
  event.dataTransfer.setData('text/plain', modelName);
}

function importFloorPlan() {
  fileInput.value.click();
}

function onFileChange(event) {
  const file = event.target.files[0];
  if (file) {
    const reader = new FileReader();
    reader.onload = (e) => {
      floorPlanSrc.value = e.target.result;
    };
    reader.readAsDataURL(file);
  }
}

function saveLayout() {
  if (threeScene.value) {
    const layout = threeScene.value.saveLayout();
    const layoutJson = JSON.stringify(layout, null, 2);
    const blob = new Blob([layoutJson], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    const projectName = prompt('请输入项目名称:', '仓库布局');
    a.download = projectName ? `${projectName}.json` : 'warehouse-layout.json';
    a.click();
    URL.revokeObjectURL(url);
  }
}

function loadLayout() {
  layoutInput.value.click();
}

function onLayoutFileChange(event) {
  const file = event.target.files[0];
  if (file) {
    const reader = new FileReader();
    reader.onload = (e) => {
      try {
        const layout = JSON.parse(e.target.result);
        if (threeScene.value) {
          threeScene.value.loadLayout(layout);
        }
      } catch (error) {
        console.error('加载布局失败:', error);
      }
    };
    reader.readAsText(file);
  }
}

function exportImage() {
  if (threeScene.value) {
    const dataURL = threeScene.value.exportImage();
    const a = document.createElement('a');
    a.href = dataURL;
    const imageName = prompt('请输入图片名称:', '仓库布局');
    a.download = imageName ? `${imageName}.png` : 'warehouse-layout.png';
    a.click();
  }
}

function clearScene() {
  if (threeScene.value) {
    threeScene.value.clearScene();
  }
}

function moveObject() {
  if (threeScene.value) {
    threeScene.value.moveObject(true);
  }
}

function startRotate() {
  if (threeScene.value) {
    if (isRotating.value) {
      // 如果已经在旋转模式，则退出
      isRotating.value = false;
      threeScene.value.endRotate();
    } else {
      // 进入旋转模式
      isRotating.value = true;
      threeScene.value.startRotate();
    }
  }
}

function deleteObject() {
  if (threeScene.value) {
    threeScene.value.deleteObject();
  }
}

function onModelAdded(model) {
  console.log('模型添加成功:', model);
}

function onLayoutSaved(layout) {
  console.log('布局保存成功:', layout);
}

function onLayoutLoaded(layout) {
  console.log('布局加载成功:', layout);
}

function onObjectSelected(object) {
  selectedObject.value = object;
  console.log('对象选中:', object);
}

function onObjectDeselected() {
  selectedObject.value = null;
  console.log('对象取消选中');
}

function onBatchPlaceCompleted() {
  isBatchPlacing.value = false;
  console.log('批量放置完成');
}

function updateBatchCount() {
  console.log('批量数量:', batchCount.value);
}

function updateBatchSpacing() {
  console.log('批量间距:', batchSpacing.value);
}

function setBatchDirection(direction) {
  batchDirection.value = direction;
  console.log('批量放置方向:', direction);
}

function startBatchPlace() {
  isBatchPlacing.value = true;
  console.log('开始批量放置模式');
  // 通知ThreeScene进入批量放置模式
  if (threeScene.value) {
    threeScene.value.enableBatchPlaceMode(batchCount.value, batchSpacing.value, batchDirection.value);
  }
}

function batchPlace() {
  if (threeScene.value) {
    threeScene.value.batchPlace('shelf_with_pallet.glb', batchCount.value, batchSpacing.value, batchDirection.value);
  }
}
</script>

<style scoped>

  font-size: 13px;
  color: #666;
  margin: 5px 0;
}

.direction-buttons {
  display: flex;
  gap: 10px;
}

.direction-buttons button {
  flex: 1;
  padding: 8px 12px;
  background-color: #f5f5f5;
  color: #333;
  border: 1px solid #ddd;
  border-radius: 4px;
  cursor: pointer;
  transition: all 0.2s;
}

.direction-buttons button.active {
  background-color: #4fc3f7;
  color: white;
  border-color: #4fc3f7;
}

.direction-buttons button:hover {
  background-color: #e0e0e0;
}


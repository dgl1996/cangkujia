  background-color: #29b6f6;
}

.batch-btn {
  background-color: #4caf50;
  color: white;
  padding: 12px;
  font-size: 14px;
  font-weight: bold;
}

.batch-btn:hover {
  background-color: #45a049;
}

.batch-btn:disabled {
  background-color: #ff9800;
  cursor: wait;
}


}

.model-list {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.model-item {
  padding: 12px;
  background-color: #f5f5f5;
  border-radius: 4px;
  cursor: grab;
  transition: background-color 0.2s;
}

.model-item:hover {
  background-color: #e0e0e0;
}

.model-item:active {
  cursor: grabbing;
}

.control-buttons {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.object-controls {
  display: flex;
  flex-direction: column;
  gap: 15px;
}


<template>
  <div class="three-scene">
    <div ref="container" class="scene-container" @dragover="onDragOver" @drop="onDrop" @click="onClick"></div>
    <img ref="floorPlan" class="floor-plan" v-if="floorPlanSrc" :src="floorPlanSrc" alt="仓库平面图">
  </div>
</template>

<script setup>
import { ref, onMounted, onUnmounted, defineProps, defineEmits } from 'vue';
import * as THREE from 'three';
import { OrbitControls } from 'three/examples/jsm/controls/OrbitControls.js';
import { GLTFLoader } from 'three/examples/jsm/loaders/GLTFLoader.js';

const props = defineProps({
  floorPlanSrc: {
    type: String,
    default: ''
  }
});

const emit = defineEmits(['model-added', 'layout-saved', 'layout-loaded', 'object-selected', 'object-deselected']);

const container = ref(null);
const floorPlan = ref(null);
let scene, camera, renderer, controls, loader, raycaster, mouse;
let sceneObjects = [];
let selectedObject = null;
let models = {};
let isMoving = false;
let movePlane = new THREE.Plane(new THREE.Vector3(0, 1, 0), 0);
let moveIntersectPoint = new THREE.Vector3();
let moveOffset = new THREE.Vector3();
let cornerMarkers = [];
let isRotating = false;
let rotationRing = null;
let rotationStartAngle = 0;
let rotationStartMouse = new THREE.Vector2();

onMounted(() => {
  // 创建场景
  scene = new THREE.Scene();
  scene.background = new THREE.Color(0xf0f0e6);

  // 创建相机
  camera = new THREE.PerspectiveCamera(
    35,
    container.value.clientWidth / container.value.clientHeight,
    0.1,
    1000
  );
  camera.position.set(10, 8, 10);

  // 创建渲染器
  renderer = new THREE.WebGLRenderer({ antialias: true });
  renderer.setSize(container.value.clientWidth, container.value.clientHeight);
  container.value.appendChild(renderer.domElement);

  // 添加轨道控制器
  controls = new OrbitControls(camera, renderer.domElement);
  controls.enableDamping = true;
  controls.dampingFactor = 0.05;

  // 添加灯光
  const ambientLight = new THREE.AmbientLight(0xffffff, 0.6);
  scene.add(ambientLight);

  const directionalLight = new THREE.DirectionalLight(0xffffff, 0.9);
  directionalLight.position.set(5, 10, 7.5);
  scene.add(directionalLight);

  // 添加网格辅助线
  const gridHelper = new THREE.GridHelper(20, 20, 0xaaaaaa, 0xdddddd);
  scene.add(gridHelper);

  // 初始化加载器
  loader = new GLTFLoader();
  raycaster = new THREE.Raycaster();
  mouse = new THREE.Vector2();

  // 预加载模型
  loadModel('shelf_with_pallet.glb');

  // 动画循环
  animate();

  // 窗口大小调整
  window.addEventListener('resize', handleResize);
  
  // 鼠标移动事件
  container.value.addEventListener('mousemove', onMouseMove);
  // 鼠标释放事件
  container.value.addEventListener('mouseup', onMouseUp);
});

onUnmounted(() => {
  window.removeEventListener('resize', handleResize);
  if (controls) {
    controls.dispose();
  }
  if (renderer) {
    renderer.dispose();
  }
});

function animate() {
  requestAnimationFrame(animate);
  if (controls) {
    controls.update();
  }
  if (renderer && scene && camera) {
    renderer.render(scene, camera);
  }
}

function handleResize() {
  if (camera && renderer && container.value) {
    camera.aspect = container.value.clientWidth / container.value.clientHeight;
    camera.updateProjectionMatrix();
    renderer.setSize(container.value.clientWidth, container.value.clientHeight);
  }
}

function loadModel(modelName) {
  if (models[modelName]) {
    return models[modelName];
  }

  loader.load(
    `/assets/${modelName}`,
    (gltf) => {
      const model = gltf.scene;
      
      // 旋转模型使其站立
      model.rotation.x = -Math.PI / 2;
      
      // 计算模型的边界框
      const box = new THREE.Box3().setFromObject(model);
      
      // 调整模型位置，使底部与地面平齐（Y=0）
      const offsetY = -box.min.y;
      model.position.y = offsetY;
      
      models[modelName] = model;
      console.log('模型加载成功:', modelName);
    },
    (xhr) => {
      console.log((xhr.loaded / xhr.total * 100) + '% loaded');
    },
    (error) => {
      console.error('模型加载失败:', error);
    }
  );
}

function onDragOver(event) {
  event.preventDefault();
}

function onDrop(event) {
  event.preventDefault();
  const modelName = event.dataTransfer.getData('text/plain');
  
  // 计算鼠标位置
  mouse.x = (event.clientX / container.value.clientWidth) * 2 - 1;
  mouse.y = -(event.clientY / container.value.clientHeight) * 2 + 1;
  
  // 发射射线
  raycaster.setFromCamera(mouse, camera);
  
  // 创建一个平面用于检测
  const plane = new THREE.Plane(new THREE.Vector3(0, 1, 0), 0);
  const intersectPoint = new THREE.Vector3();
  raycaster.ray.intersectPlane(plane, intersectPoint);
  
  if (intersectPoint && models[modelName]) {
    // 克隆模型
    const newModel = models[modelName].clone();
    
    // 确保每个模型的材质都是独立的，避免共享材质导致的高亮问题
    newModel.traverse((child) => {
      if (child.material) {
        child.material = child.material.clone();
      }
    });
    
    // 确保对象放置在水平面上（Y=0），X和Z坐标对齐网格（精度0.1米）
    newModel.position.set(Math.round(intersectPoint.x * 10) / 10, newModel.position.y, Math.round(intersectPoint.z * 10) / 10);
    scene.add(newModel);
    sceneObjects.push(newModel);
    console.log('模型添加到场景:', newModel.position, 'sceneObjects数量:', sceneObjects.length);
    emit('model-added', newModel);
  }
}

function onClick(event) {
  // 计算鼠标位置
  const rect = container.value.getBoundingClientRect();
  mouse.x = ((event.clientX - rect.left) / container.value.clientWidth) * 2 - 1;
  mouse.y = -((event.clientY - rect.top) / container.value.clientHeight) * 2 + 1;
  
  // 发射射线
  raycaster.setFromCamera(mouse, camera);
  
  if (isMoving && selectedObject) {
    // 计算鼠标在平面上的交点
    if (raycaster.ray.intersectPlane(movePlane, moveIntersectPoint)) {
      selectedObject.position.copy(moveIntersectPoint.sub(moveOffset));
    }
  } else {
    // 检测与场景中对象的交互
    const intersects = raycaster.intersectObjects(sceneObjects, true);
    
    console.log('射线检测结果:', intersects.length, 'sceneObjects数量:', sceneObjects.length);
    
    // 移除之前选中对象的高亮
    if (selectedObject) {
      selectedObject.traverse((child) => {
        if (child.material) {
          child.material.emissive.setHex(0x000000);
        }
      });
    }
    
    if (intersects.length > 0) {
      // 找到最接近的对象
      const closestObject = intersects[0].object;
      // 找到对象的根节点
      let rootObject = closestObject;
      while (rootObject.parent && rootObject.parent !== scene) {
        rootObject = rootObject.parent;
      }
      // 选中对象
      selectedObject = rootObject;
      // 添加选中高亮效果
      selectedObject.traverse((child) => {
        if (child.material) {
          child.material.emissive.setHex(0x4fc3f7);
          child.material.emissiveIntensity = 0.3;
        }
      });
      // 触发选中事件
      emit('object-selected', selectedObject);
      // 更新角落标记
      updateCornerMarkers();
    } else {
      // 取消选择
      selectedObject = null;
      emit('object-deselected');
      // 清除角落标记
      cornerMarkers.forEach(marker => scene.remove(marker));
      cornerMarkers = [];
    }
  }
}

function onMouseMove(event) {
  const rect = container.value.getBoundingClientRect();
  mouse.x = ((event.clientX - rect.left) / container.value.clientWidth) * 2 - 1;
  mouse.y = -((event.clientY - rect.top) / container.value.clientHeight) * 2 + 1;
  
  // 旋转模式
  if (isRotating && selectedObject && rotationRing) {
    // 计算鼠标相对于旋转环中心的角度
    const box = new THREE.Box3().setFromObject(selectedObject);
    const center = box.getCenter(new THREE.Vector3());
    
    // 将鼠标位置转换到世界坐标
    raycaster.setFromCamera(mouse, camera);
    const plane = new THREE.Plane(new THREE.Vector3(0, 1, 0), 0);
    const intersectPoint = new THREE.Vector3();
    if (raycaster.ray.intersectPlane(plane, intersectPoint)) {
      // 计算鼠标相对于模型中心的角度
      const dx = intersectPoint.x - center.x;
      const dz = intersectPoint.z - center.z;
      const angle = Math.atan2(dz, dx) * 180 / Math.PI;
      
      // 应用旋转（加上90度偏移，使0度指向右侧）
      selectedObject.rotation.z = -angle * Math.PI / 180 + Math.PI / 2;
      updateCornerMarkers();
      showRotationRing(); // 更新旋转环
    }
    return;
  }
  
  // 移动模式
  if (isMoving && selectedObject) {
    // 发射射线
    raycaster.setFromCamera(mouse, camera);
    
    // 计算鼠标在平面上的交点
    if (raycaster.ray.intersectPlane(movePlane, moveIntersectPoint)) {
      // 计算目标位置
      const targetPosition = moveIntersectPoint.sub(moveOffset);
      // 确保对象在水平面上移动，保持Y坐标不变
      targetPosition.y = selectedObject.position.y;
      // 自动对齐到网格（精度0.1米）
      targetPosition.x = Math.round(targetPosition.x * 10) / 10;
      targetPosition.z = Math.round(targetPosition.z * 10) / 10;
      // 移动对象
      selectedObject.position.copy(targetPosition);
    }
  }
}

function onMouseUp(event) {
  if (isRotating) {
    // 旋转模式结束
    isRotating = false;
    hideRotationRing();
    container.value.style.cursor = 'crosshair';
    console.log('旋转完成');
  }
  isMoving = false;
  container.value.style.cursor = 'crosshair';
  updateCornerMarkers();
}

function createCornerMarker() {
  const geometry = new THREE.CircleGeometry(0.2, 16);
  const material = new THREE.MeshBasicMaterial({ color: 0x4caf50, transparent: true, opacity: 0.7 });
  return new THREE.Mesh(geometry, material);
}

function createRotationRing() {
  // 创建圆环几何体
  const geometry = new THREE.RingGeometry(1.5, 1.7, 32);
  const material = new THREE.MeshBasicMaterial({ 
    color: 0x4fc3f7, 
    transparent: true, 
    opacity: 0.6,
    side: THREE.DoubleSide
  });
  const ring = new THREE.Mesh(geometry, material);
  ring.rotation.x = -Math.PI / 2; // 平放在地面上
  return ring;
}

function showRotationRing() {
  // 清除之前的旋转环
  hideRotationRing();
  
  if (selectedObject) {
    // 计算模型的边界框
    const box = new THREE.Box3().setFromObject(selectedObject);
    const center = box.getCenter(new THREE.Vector3());
    
    // 创建旋转环
    rotationRing = createRotationRing();
    rotationRing.position.set(center.x, 0.1, center.z); // 稍微高于地面
    
    // 根据模型大小调整旋转环大小
    const size = box.getSize(new THREE.Vector3());
    const maxSize = Math.max(size.x, size.z);
    rotationRing.scale.set(maxSize / 2, maxSize / 2, 1);
    
    scene.add(rotationRing);
    console.log('显示旋转环');
  }
}

function hideRotationRing() {
  if (rotationRing) {
    scene.remove(rotationRing);
    rotationRing = null;
    console.log('隐藏旋转环');
  }
}

function updateCornerMarkers() {
  // 清除现有标记
  cornerMarkers.forEach(marker => scene.remove(marker));
  cornerMarkers = [];
  
  if (selectedObject) {
    // 计算对象的边界框
    const box = new THREE.Box3().setFromObject(selectedObject);
    
    // 计算4个角落的位置（在Y=0平面上）
    const corners = [
      new THREE.Vector3(box.min.x, 0, box.min.z),
      new THREE.Vector3(box.max.x, 0, box.min.z),
      new THREE.Vector3(box.max.x, 0, box.max.z),
      new THREE.Vector3(box.min.x, 0, box.max.z)
    ];
    
    // 创建并添加标记
    corners.forEach(corner => {
      const marker = createCornerMarker();
      marker.position.copy(corner);
      marker.rotation.x = -Math.PI / 2;
      scene.add(marker);
      cornerMarkers.push(marker);
    });
  }
}

defineExpose({
  saveLayout: () => {
    const layout = {
      objects: sceneObjects.map(obj => ({
        modelName: 'shelf_with_pallet.glb',
        position: obj.position.toArray(),
        rotation: obj.rotation.toArray(),
        scale: obj.scale.toArray()
      }))
    };
    return layout;
  },
  loadLayout: (layout) => {
    // 清除现有对象
    sceneObjects.forEach(obj => scene.remove(obj));
    sceneObjects = [];
    
    // 加载新对象
    if (layout.objects) {
      layout.objects.forEach(objData => {
        if (models[objData.modelName]) {
          const newModel = models[objData.modelName].clone();
          newModel.position.fromArray(objData.position);
          newModel.rotation.fromArray(objData.rotation);
          newModel.scale.fromArray(objData.scale);
          scene.add(newModel);
          sceneObjects.push(newModel);
        }
      });
    }
    emit('layout-loaded');
  },
  clearScene: () => {
    sceneObjects.forEach(obj => scene.remove(obj));
    sceneObjects = [];
    selectedObject = null;
    cornerMarkers.forEach(marker => scene.remove(marker));
    cornerMarkers = [];
  },
  startRotate: () => {
    if (selectedObject) {
      isRotating = true;
      showRotationRing();
      container.value.style.cursor = 'grab';
      console.log('进入旋转模式，请拖动旋转环');
    }
  },
  
  endRotate: () => {
    isRotating = false;
    hideRotationRing();
    container.value.style.cursor = 'crosshair';
    console.log('退出旋转模式');
  },
  
  rotateObject: (angle) => {
    if (selectedObject) {
      // 简单的绕中心旋转
      const rad = -angle * Math.PI / 180;
      selectedObject.rotation.z = rad;
      updateCornerMarkers();
      if (rotationRing) {
        showRotationRing(); // 更新旋转环位置
      }
    }
  },
  moveObject: (startMoving) => {
    if (startMoving && selectedObject) {
      isMoving = true;
      container.value.style.cursor = 'move';
      moveOffset.set(0, 0, 0);
    } else {
      isMoving = false;
      container.value.style.cursor = 'crosshair';
    }
  },
  deleteObject: () => {
    if (selectedObject) {
      const index = sceneObjects.indexOf(selectedObject);
      if (index > -1) {
        selectedObject.traverse((child) => {
          if (child.material) {
            child.material.emissive.setHex(0x000000);
          }
        });
        scene.remove(selectedObject);
        sceneObjects.splice(index, 1);
        selectedObject = null;
      }
    }
  },
  exportImage: () => {
    renderer.setSize(container.value.clientWidth, container.value.clientHeight);
    renderer.render(scene, camera);
    const dataURL = renderer.domElement.toDataURL('image/png');
    return dataURL;
  }
});
</script>

<style scoped>
.three-scene {
  width: 100%;
  height: 100%;
  position: relative;
}

.scene-container {
  width: 100%;
  height: 100%;
  cursor: crosshair;
}

.floor-plan {
  position: absolute;
  bottom: 20px;
  right: 20px;
  max-width: 200px;
  max-height: 200px;
  border: 2px solid #ddd;
  border-radius: 4px;
  opacity: 0.8;
}
</style>